# .env.example
# Sentinel — Environment Variable Template
# Copy this to .env and fill in real values. NEVER commit .env to version control.

# ─────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────
POSTGRES_USER=sentinel_user
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=sentinel_db

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─────────────────────────────────────────
# JWT Authentication
# ─────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=replace_with_64_char_hex_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# Application
# ─────────────────────────────────────────
APP_ENV=development                          # Options: development | production

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ─────────────────────────────────────────
# Frontend (Vite)
# ─────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8000
